{
  "name": "@s4ai/merkaba-geoqode-lattice",
  "version": "1.0.0",
  "description": "MERKABA_geoqode Lattice480: lattice runtime core for the Merkaba48OS unified launcher",
  "type": "module",
  "main": "geo/index.js",
  "scripts": {
    "start": "node --max-old-space-size=1024 server.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "parse": "node scripts/parse.js",
    "run": "node scripts/run.js",
    "benchmark:lattice": "node scripts/benchmark-lattice.js",
    "benchmark:lattice:real": "node scripts/benchmark-lattice.js --real",
    "codex:upgrade": "node scripts/transform-codex.js",
    "compliance-check": "node scripts/compliance-check.js",
    "status-report": "node scripts/generate-status-report.js",
    "build": "echo 'GeoQode is interpreted — no build step required'",
    "lint": "eslint geo/ tests/",
    "docs:build": "echo 'Documentation is markdown-based'"
  },
  "keywords": [
    "geoqode",
    "merkaba",
    "lattice480",
    "merkaba48os",
    "ai-os",
    "resonance",
    "geometry",
    "quantum",
    "compliance"
  ],
  "author": "Bradley Levitan <bradleylevitan@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "sharp": "^0.34.5",
    "vitest": "^4.1.5"
  }
}
