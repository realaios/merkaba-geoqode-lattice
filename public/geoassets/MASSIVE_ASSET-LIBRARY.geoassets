    "nano_bloodstream": {
      "id": "nano_bloodstream",
      "title": "Nano Bloodstream — Inner Universe",
      "logline": "Microscopic journey through a human blood vessel. Red cells at human scale. You are 37 trillion cells.",
      "palette": "quantum",
      "sound": "ambient_heartbeat",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "You're inside a capillary 0.008mm wide.\nScaled to walking size, a red blood cell is the size of a football.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "Your heart pumps 7,000 litres of blood per day.\nThe entire journey around your body takes 23 seconds.",
          "durationMs": 7000
        },
        {
          "trigger": "step_2",
          "text": "Every red blood cell carries 270 million haemoglobin molecules.\nEach one can carry 4 oxygen atoms. You are extraordinary.",
