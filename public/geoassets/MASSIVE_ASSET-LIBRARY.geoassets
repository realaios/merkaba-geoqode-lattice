    "church_square_vr": {
      "id": "church_square_vr",
      "title": "Church Square — Blaubeuren, Bavaria",
      "logline": "A medieval Bavarian market square. Half-timbered buildings. Church spires piercing blue sky.",
      "palette": "golden_hour",
      "sound": "ambient_city",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Blaubeuren has been continuously inhabited since the Stone Age.\nThis square has hosted markets for 800 years.\nSome places simply refuse to stop mattering.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "Half-timbered buildings like these were the dominant European architecture for 400 years.\nThe timber frame is structural. The infill can change.\nFlexibility built into the bones of the building.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "The Blautopf spring near here produces 2,000 litres per second.\nIts blue colour comes from tiny chalk particles.\nWater this pure was what settled cities for thousands of years.",
          "durationMs": 8000
        }
      ],
      "environment": {
        "sky": {
