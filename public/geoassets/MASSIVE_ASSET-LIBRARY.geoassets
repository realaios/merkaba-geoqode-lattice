    "ocean_beach_vr": {
      "id": "ocean_beach_vr",
      "title": "Ocean Beach — Horizon Drift",
      "logline": "A wide beach at low tide. The sea pulls back. Wet sand reflects the sky.",
      "palette": "ocean",
      "sound": "ambient_ocean",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "The ocean covers 71% of Earth's surface and produces 70% of its oxygen.\nMost of it is unexplored — we have better maps of the moon than of our ocean floor.\nThe sea is the largest unknown on our own planet.",
          "durationMs": 8000
        },
        {
          "trigger": "step_1",
          "text": "A beach is a temporary archive.\nTides rewrite it twice a day. Storms can move a beach by metres in hours.\nYet beaches persist for thousands of years, always changing, always returning.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "The Pacific Ocean is larger than all of Earth's landmass combined.\nIf you removed all land from the planet and filled the basin with water, it would cover everything.\nThe ocean is the planet's default state. Land is the exception.",
          "durationMs": 9000
        }
      ],
      "environment": {
