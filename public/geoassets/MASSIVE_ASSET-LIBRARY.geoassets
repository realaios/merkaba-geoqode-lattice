    "abandoned_factory_vr": {
      "id": "abandoned_factory_vr",
      "title": "Abandoned Factory — Industrial Ruins",
      "logline": "A derelict industrial plant, silent machines frozen in time. Rust and memory.",
      "palette": "simulation",
      "sound": "ambient_city",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "At its peak, this factory employed 4,000 workers across three shifts.\nThe last worker clocked out in 1987. The machines have not moved since.\nSilence has a texture in places like this.",
          "durationMs": 8000
        },
        {
          "trigger": "step_1",
          "text": "Rust is iron returning to its natural state.\nMetal remembers what it once was — ore pulled from the earth.\nDecay is not failure. It is completion.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
