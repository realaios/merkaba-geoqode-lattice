    "autumn_meadow_vr": {
      "id": "autumn_meadow_vr",
      "title": "Autumn Meadow — Golden October",
      "logline": "Amber grasses, rusted oaks, afternoon sun at low angle. The year's most beautiful ending.",
      "palette": "golden_hour",
      "sound": "ambient_wind",
      "narrativeBeats": [
