    "urban_street_vr": {
      "id": "urban_street_vr",
      "title": "Urban Street — City Grid",
      "logline": "Wet asphalt, steel and glass. The grid of modern civilization mapped in concrete and neon.",
      "palette": "simulation",
      "sound": "ambient_city",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Every street is a decision made by someone a century ago.\nYou walk through other people's choices every day.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "The Romans built straight roads because straight armies march faster.\nAnd we still drive the same roads, 2000 years later.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "53 million surveillance cameras watch China's streets.\nIn a city of 10 million, that's 5 cameras per person.\nThe city always sees back.",
