    "moon_lab_vr": {
      "id": "moon_lab_vr",
      "title": "Moon Laboratory — Lunar Research",
      "logline": "A lunar research base on the moon's surface. Earth rises above the crater rim.",
      "palette": "orbital",
      "sound": "ambient_cosmic",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "The moon has no atmosphere. Sound cannot travel. It is the most silent place reachable by humans.\nThe only sounds an astronaut hears are inside their own suit.\nSilence at this scale is a different substance.",
          "durationMs": 9000
        },
        {
          "trigger": "step_1",
          "text": "The lunar surface has been undisturbed for 3 billion years in most places.\nAstronaut footprints from 1969 are still perfectly preserved.\nWithout weather, history is literally written in the ground.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "A lunar day lasts 29.5 Earth days.\nTemperature swings from +127°C in sunlight to -173°C in shadow.\nThe moon teaches you that all weather is atmospheric — remove the atmosphere, reality hardens.",
          "durationMs": 9000
        }
      ],
      "environment": {
        "sky": {
          "color": "#000000"
        },
        "fog": {
