    "volcanic_summit_vr": {
      "id": "volcanic_summit_vr",
      "title": "Volcanic Summit — Lava Crown",
      "logline": "At the crater rim of an active volcano. Heat shimmers. The planet breathes.",
      "palette": "desert_dawn",
      "sound": "ambient_wind",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Earth has 1,500 potentially active volcanoes.\n80% of the planet's surface was formed by volcanic activity.\nThe ground you stand on anywhere began as magma.",
          "durationMs": 8000
        },
        {
          "trigger": "step_1",
          "text": "Kilauea volcano in Hawaii has been erupting continuously since 1983.\nIt has added 875 acres of new land to the Big Island.\nCreation and destruction are the same geological process.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "The temperature at the centre of Earth's core is 5,200°C — as hot as the sun's surface.\nThe entire planet is a cooling body of magma with a thin cooled crust we call home.\nThe ground is the least solid thing about us.",
          "durationMs": 9000
        }
      ],
      "environment": {
