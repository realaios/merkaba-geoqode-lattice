    "railway_bridge_vr": {
      "id": "railway_bridge_vr",
      "title": "Railway Bridges — Iron Arch",
      "logline": "Victorian railway viaducts spanning a valley. Iron and brick. The industrial sublime.",
      "palette": "deep_space",
      "sound": "ambient_city",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "The first railway bridge to span a major river opened in 1850.\nIn 50 years, iron viaducts had threaded through every mountain range in Europe.\nSpeed changed everything.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "Brunel’s Clifton Suspension Bridge was designed when he was 24.\nIt took 33 years to build. He died before it opened.\nThe greatest things are often finished by others.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "Railway bridges are designed to last 100 years.\nMany Victorian bridges are now 150+ years old and still carry trains daily.\nOverengineering is another word for respect for the future.",
          "durationMs": 8000
        }
      ],
      "environment": {
