    "spacex_capsule": {
      "id": "spacex_capsule",
      "title": "SpaceX Dragon Capsule — LEO",
      "logline": "Inside a Dragon capsule in low Earth orbit. Touchscreens. Hatch window. Earth below at 28,000 km/h.",
      "palette": "orbital",
      "sound": "ambient_space_hum",
      "narrativeBeats": [
