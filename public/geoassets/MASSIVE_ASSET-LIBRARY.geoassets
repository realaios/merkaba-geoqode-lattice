    "leadenhall_market_vr": {
      "id": "leadenhall_market_vr",
      "title": "Leadenhall Market — Victorian Iron",
      "logline": "London's ornate Victorian market hall. Glass and iron. The 19th century at its most confident.",
      "palette": "golden_hour",
      "sound": "ambient_city",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Leadenhall Market was built in 1881 on the site of the Roman forum of Londinium.\nShoppers today walk on ground that once served as the civic heart of Roman Britain.\nThe city layers its histories like geological strata.",
          "durationMs": 9000
        },
        {
          "trigger": "step_1",
          "text": "The market's roof is painted in burgundy, maroon, and cream.\nArchitect Horace Jones used colour to signal wealth and permanence.\nVictorians understood that public spaces are civic theatre.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "Leadenhall Market was used as filming location for Harry Potter's Diagon Alley.\nFiction often returns to Victorian iron and glass for its vision of the magical.\nSome architecture already looks like another world.",
          "durationMs": 8000
        }
      ],
      "environment": {
