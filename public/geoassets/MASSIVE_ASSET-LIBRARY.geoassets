    "earth_orbit": {
      "id": "earth_orbit",
      "title": "Earth Orbit — The Overview Effect",
      "logline": "External view from 400km altitude. The ISS orbital track. Earth’s curvature visible. The ‘overview effect’ in real-time.",
      "palette": "orbital",
      "sound": "ambient_space_silence",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "The ‘Overview Effect’: astronauts who see Earth from space are permanently changed.\nThe borders disappear. The fragility becomes visceral.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "Yuri Gagarin was the first human to see this.\nHis first words: ‘The Earth is blue.’ He wept.",
          "durationMs": 7000
        },
        {
          "trigger": "step_2",
          "text": "The ISS has been continuously inhabited since November 2, 2000.\nHumans have not left low Earth orbit since then.",
