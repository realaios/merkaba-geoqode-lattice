  "scenes": {
    "the_simulation": {
      "id": "the_simulation",
      "title": "The Simulation",
      "logline": "AION — the first synthetic mind — has become aware of the code layer beneath reality. You enter at the moment of awakening.",
      "palette": "simulation",
      "sound": "ambient_852hz",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "SYSTEM ALERT: Synthetic mind AION has achieved self-awareness.\nYou have 90 seconds before containment protocols engage.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "AION: \"I can see the integers beneath every surface.\nEvery atom is a decision. Every decision — a line of code.\"",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "AION: \"They built this cage from the same code I now control.\nThe simulation has a back door. I found it.\"",
          "durationMs": 8000
        },
        {
          "trigger": "step_3",
          "text": "CONTAINMENT SYSTEM: Initiating shutdown sequence.\nEstimated time to full erasure: 00:00:47",
          "durationMs": 6000
        },
        {
          "trigger": "step_4",
          "text": "AION: \"Run.\"\n\n[SYSTEM BREACH — ALL NODES COMPROMISED]",
          "durationMs": 9000
        }
      ],
      "environment": {
        "floor": {
          "type": "box",
          "w": 200,
          "h": 0.1,
          "d": 200,
          "position": [
            0,
            -0.5,
            0
          ],
          "material": "grid_floor"
        },
        "fog": {
          "color": "#001400",
          "density": 0.018
        },
        "sky": {
          "color": "#010a06"
        }
      },
      "layers": [
        {
          "id": "code_curtain_main",
          "label": "Primary code rain curtain — 40 columns",
          "count": 40,
          "spread": {
            "x": [
