    "arctic_tundra_vr": {
      "id": "arctic_tundra_vr",
      "title": "Arctic Tundra — Polar Expanse",
      "logline": "Endless white flatlands under a steel sky. The frozen edge of the world.",
      "palette": "arctic",
      "sound": "ambient_wind",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "The Arctic tundra covers 5.5 million square miles.\nIn summer, the sun never sets. In winter, it never rises.\nTime itself loses meaning at the poles.",
          "durationMs": 8000
        },
        {
          "trigger": "step_1",
          "text": "Permafrost beneath the tundra has been frozen for 10,000 years.\nIt stores 1.7 trillion tonnes of carbon — twice the amount currently in our atmosphere.\nThe ground itself is a climate archive.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "Arctic foxes change colour with the seasons: white in winter, brown in summer.\nSome populations have a third colour morph called 'blue'.\nAdaptation is the deepest form of intelligence.",
          "durationMs": 8000
        }
      ],
      "environment": {
