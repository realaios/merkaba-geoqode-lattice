    "waterfall_valley_vr": {
      "id": "waterfall_valley_vr",
      "title": "Waterfall Valley — Lauter Falls",
      "logline": "A valley carved by water over millennia. The constant percussion of a 20-metre waterfall.",
      "palette": "forest",
      "sound": "ambient_water",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Water dissolves rock at 1mm per thousand years.\nThis valley is the sum of a billion patient moments.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "The roar of a large waterfall is caused by air, not water.\nMicrobubbles of air imploding in the plunge pool create the sound.\nNature makes noise by crushing the invisible.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "Waterfalls produce negative ions.\nStudies show 20 minutes near one reduces cortisol by 12%.\nBeauty heals. This has been measurable for a century. We only just started studying it.",
