    "grand_canyon": {
      "id": "grand_canyon",
      "title": "Grand Canyon — Geological Deep Time",
      "logline": "Rim of the Grand Canyon at golden hour. 1.7 billion years of Earth history visible in one view.",
      "palette": "desert_dawn",
      "sound": "ambient_wind_canyon",
      "narrativeBeats": [
