    "venice_dawn_vr": {
      "id": "venice_dawn_vr",
      "title": "Venice at Dawn — Canals and Light",
      "logline": "Morning light on Venetian water. Stone arches, gondola reflections, amber rising over the Adriatic.",
      "palette": "golden_hour",
      "sound": "ambient_water",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Venice is sinking at 2mm per year.\nAnd yet, 400 years of masters painted nothing but light on water.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "Venetian glass was so valuable, glassblowers were confined to Murano island.\nTo stop the secrets leaking out.\nBeauty has always been guarded.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "'Canaletto painted Venice so precisely,\nscholars used his art to date floods in the historical record.\nArt as scientific data.",
          "durationMs": 8000
        }
      ],
      "environment": {
        "sky": {
          "color": "#fed7aa"
        },
        "fog": {
          "color": "#fde68a",
          "density": 0.012
        }
      },
      "layers": [
        {
          "id": "canal_water",
          "label": "Venice canal water surface",
          "type": "plane",
          "w": 80,
          "h": 120,
          "position": [
