    "lakeside_dawn_vr": {
      "id": "lakeside_dawn_vr",
      "title": "Lakeside at Dawn — Still Water",
      "logline": "A lake at first light. Mist on the surface. The world holding its breath before the day begins.",
      "palette": "forest",
      "sound": "ambient_water",
      "narrativeBeats": [
