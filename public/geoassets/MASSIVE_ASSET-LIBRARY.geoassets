    "dikhololo_night": {
      "id": "dikhololo_night",
      "title": "Dikhololo — African Savanna Night",
      "logline": "Southern African game reserve at midnight. Polyhaven starfield. The original human sky.",
      "palette": "deep_space",
      "sound": "ambient_savanna_night",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "This is the sky our ancestors navigated by for 300,000 years.\nNo light pollution. No notifications. Just stars.",
          "durationMs": 7000
