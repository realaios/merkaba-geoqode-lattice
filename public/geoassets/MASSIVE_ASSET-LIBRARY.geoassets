    "moonlit_night_vr": {
      "id": "moonlit_night_vr",
      "title": "Moonlit Night — Quiet Glow",
      "logline": "A pastoral landscape under a full moon. Silver light on fields. The world at rest.",
      "palette": "abyss",
      "sound": "ambient_wind",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "The full moon is 400,000 times dimmer than the sun.\nYet it casts enough light to read by, to navigate by, to plant crops by.\nSufficiency is not brightness. It is the right amount of light.",
          "durationMs": 8000
        },
        {
          "trigger": "step_1",
          "text": "Before artificial lighting, the full moon was a social event.\nFarms held harvest dances by moonlight. Markets opened at midnight.\nThe moon once structured human time as completely as the clock does now.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "Moonlight is reflected sunlight delayed by 1.3 seconds.\nYou are seeing where the sun was 1.3 seconds ago, bounced off the moon's surface.\nAll light is a message from the past.",
          "durationMs": 8000
        }
      ],
      "environment": {
        "sky": {
          "color": "#0f172a"
        },
        "fog": {
