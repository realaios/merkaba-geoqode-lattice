    "abandoned_church_vr": {
      "id": "abandoned_church_vr",
      "title": "Abandoned Church — Eerie Silence",
      "logline": "A ruined church swallowed by vegetation. Silence where hymns once echoed. Nature reclaiming the sacred.",
      "palette": "abyss",
      "sound": "ambient_forest",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Abandoned churches outnumber active ones in many European nations.\nThe buildings remain. The congregations are gone.\nArchitecture outlasts belief.",
          "durationMs": 6000
        },
        {
          "trigger": "step_1",
          "text": "The Church of the Good Shepherd in New Zealand\nstood empty for 80 years before tourism made it famous.\nNeglect and rediscovery happen in cycles.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "Vegetation breaks stone at 1–2mm per year.\nIn 200 years, vines can collapse a cathedral.\nNature is the patient architect.",
          "durationMs": 7000
        }
      ],
      "environment": {
