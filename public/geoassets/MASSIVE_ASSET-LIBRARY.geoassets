    "snowy_forest_vr": {
      "id": "snowy_forest_vr",
      "title": "Snowy Forest — Winter Silence",
      "logline": "Snow-laden pine branches. The deep quiet of a forest after heavy snowfall. Every sound muffled.",
      "palette": "arctic",
      "sound": "ambient_wind",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Fresh snow absorbs sound at 60%.\nThe silence you feel in a winter forest is physics, not mood.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "A single mature pine tree drops 40kg of snow from its branches each winter.\nNature resets by letting things fall.",
          "durationMs": 7000
        },
        {
          "trigger": "step_2",
          "text": "Trees communicate through mycorrhizal networks under the snow.\nA mother tree shares sugar with seedlings all winter.\nThe forest never abandons its young.",
