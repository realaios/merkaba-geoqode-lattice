  "animations": {
    "slow_rotate_y": {
      "property": "rotation",
      "to": "0 360 0",
      "dur": 20000,
      "easing": "linear",
      "loop": true
    },
    "slow_rotate_x": {
      "property": "rotation",
      "to": "360 0 0",
      "dur": 25000,
      "easing": "linear",
      "loop": true
    },
    "slow_rotate_z": {
      "property": "rotation",
      "to": "0 0 360",
      "dur": 30000,
      "easing": "linear",
      "loop": true
    },
    "drift_up": {
      "property": "position",
      "to": "0 0.4 0",
      "dur": 3000,
      "easing": "easeInOutSine",
      "loop": true,
      "dir": "alternate"
    },
    "drift_up_slow": {
      "property": "position",
      "to": "0 0.25 0",
      "dur": 5000,
      "easing": "easeInOutSine",
      "loop": true,
      "dir": "alternate"
    },
    "pulse_opacity": {
