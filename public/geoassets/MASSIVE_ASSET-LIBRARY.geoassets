    "grand_canyon_vr": {
      "id": "grand_canyon_vr",
      "title": "Grand Canyon — Ancient Chasm",
      "logline": "Standing on the rim of the Grand Canyon. Two billion years of Earth's history in one view.",
      "palette": "desert_dawn",
      "sound": "ambient_wind",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "The Grand Canyon is 277 miles long, 18 miles wide, and over a mile deep.\nThe Colorado River has been carving it for 5 to 6 million years.\nBut the rocks at the bottom are 1.8 billion years old.",
          "durationMs": 8000
        },
        {
          "trigger": "step_1",
          "text": "Each layer of the canyon wall is a chapter in Earth's history.\nThe Kaibab Limestone at the top was laid down 270 million years ago as a shallow sea.\nThe canyon is a library written in stone.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "The Grand Canyon creates its own weather system.\nTemperature difference between rim and floor can be 30°F.\nThe inner gorge creates its own thunderstorms.\nScale changes physics.",
          "durationMs": 8000
        }
      ],
      "environment": {
        "sky": {
