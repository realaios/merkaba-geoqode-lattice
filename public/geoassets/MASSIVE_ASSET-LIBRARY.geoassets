    "simons_harbour_vr": {
      "id": "simons_harbour_vr",
      "title": "Simon's Town Harbour — Cape Navy Base",
      "logline": "A historic naval harbour. Warships at anchor. The False Bay mountains watch from behind.",
      "palette": "ocean",
      "sound": "ambient_ocean",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Simon’s Town has been a naval base since 1743.\nIt changed hands between the Dutch, British, and South African Navy.\nHarbours outlast the flags that fly over them.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "The African penguin colony at Boulders Beach is just 2km from here.\nThey arrived spontaneously in 1982 — two breeding pairs.\nNow there are over 2,000. Wildlife doesn't wait for permission.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "False Bay was named by sailors who confused it with Table Bay.\nA navigational error that became a permanent feature of the map.\nMistakes, when made by enough people, become geography.",
          "durationMs": 8000
        }
      ],
      "environment": {
