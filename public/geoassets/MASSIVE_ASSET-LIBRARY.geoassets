    "frozen_lake_vr": {
      "id": "frozen_lake_vr",
      "title": "Frozen Lake — Winter Stillness",
      "logline": "A vast frozen lake under pale winter sky. Absolute silence. Ice as far as the eye can see.",
      "palette": "arctic",
      "sound": "ambient_arctic",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Ice is a mineral. Lakes freeze from the top down.\nBeneath this surface, life continues in liquid darkness.",
          "durationMs": 6000
        },
        {
          "trigger": "step_1",
          "text": "Lake Baikal in Siberia freezes to 1.5 metres thick each winter.\nFor months, trucks drive across it as a highway.\nThe road exists only as long as the cold holds.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "The world’s frozen lakes are shrinking.\n230,000 lakes have lost at least one month of ice cover since 1990.\nWinter, too, has a deadline.",
