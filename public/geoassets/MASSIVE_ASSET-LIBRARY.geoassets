    "blouberg_sunrise_vr": {
      "id": "blouberg_sunrise_vr",
      "title": "Blouberg Sunrise — Cape Town Bay",
      "logline": "Dawn over Table Bay. Table Mountain silhouetted. Cape Town waking beneath a painted sky.",
      "palette": "golden_hour",
      "sound": "ambient_ocean",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Bloubergstrand means “Blue Mountain Beach” in Afrikaans.\nIt offers the most photographed view of Table Mountain on Earth.",
          "durationMs": 6000
        },
        {
          "trigger": "step_1",
          "text": "Table Mountain is 600 million years old.\nIt predates most life on Earth.\nThe flat top was created by 1km of ice during a global glaciation.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "Cape Town faces the most severe water crisis of any major city.\nDay Zero — when taps run dry — was narrowly avoided in 2018.\nThe mountain that defines the city may outlast its water supply.",
          "durationMs": 9000
        }
      ],
      "environment": {
