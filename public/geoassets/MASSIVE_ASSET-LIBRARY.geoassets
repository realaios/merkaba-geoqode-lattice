    "cobblestone_night_vr": {
      "id": "cobblestone_night_vr",
      "title": "Cobblestone Night — Old City Street",
      "logline": "Wet cobblestones reflecting amber streetlights. A European night alive with quiet history.",
      "palette": "merkaba",
      "sound": "ambient_rain",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Cobblestone streets predate concrete by 4,000 years.\nThese stones were laid by hand, one by one.",
          "durationMs": 6000
        },
        {
          "trigger": "step_1",
          "text": "Medieval cities were built at walking pace.\nEvery street, every stone planned for foot traffic.\nThen the car arrived, and everything widened.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "Paris nearly destroyed its cobblestone streets in the 1970s.\nA preservation movement saved 2,000 km of them.\nSometimes tradition is just the future we forgot to protect.",
          "durationMs": 9000
        }
