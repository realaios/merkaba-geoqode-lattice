    "dikhololo_night_vr": {
      "id": "dikhololo_night_vr",
      "title": "Dikhololo Night — African Twilight",
      "logline": "A South African reserve at night. Fireflies and stars. The sound of Africa sleeping.",
      "palette": "abyss",
      "sound": "ambient_wind",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Dikhololo is a private game reserve 90km north of Pretoria, South Africa.\nAt night, the Milky Way is fully visible — there is almost no light pollution.\nThe further from cities, the further into time you can see.",
          "durationMs": 8000
        },
        {
          "trigger": "step_1",
          "text": "Impala are crepuscular — most active at dawn and dusk.\nThey feed for 30 minutes, then watch for predators for 30 minutes. Continuously.\nVigilance is the price of survival in an open landscape.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "The Milky Way seen from the Southern Hemisphere shows the galactic core.\nYou see the brightest, densest part of our galaxy — not visible from northern latitudes.\nWhere you stand on Earth determines what you can see of the universe.",
          "durationMs": 9000
        }
      ],
      "environment": {
