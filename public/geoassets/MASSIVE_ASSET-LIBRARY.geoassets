    "evening_street_vr": {
      "id": "evening_street_vr",
      "title": "Evening Street — Modern City Dusk",
      "logline": "A contemporary city street at dusk. Glass towers glow gold. The day dissolves into blue hour.",
      "palette": "simulation",
      "sound": "ambient_city",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "The “blue hour” lasts only 20–40 minutes after sunset.\nPhotographers call it the most honest light in the world.",
          "durationMs": 6000
        },
        {
          "trigger": "step_1",
          "text": "Modern cities emit 70% of all global carbon dioxide.\nAnd yet they’re also where 80% of GDP is created.\nThe city is both the problem and the solution.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "In 1800, 3% of humanity lived in cities.\nIn 2050, it will be 68%.\nWe are becoming an urban species.",
