    "autumn_forest_vr": {
      "id": "autumn_forest_vr",
      "title": "Autumn Forest — Golden Canopy",
      "logline": "A forest ablaze with amber and crimson. The year’s most fleeting beauty measured in weeks.",
      "palette": "forest",
      "sound": "ambient_jungle",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Autumn colour is not death — it’s the tree reclaiming its chlorophyll.\nGold and red were always there, hidden beneath the green.",
          "durationMs": 6000
        },
        {
          "trigger": "step_1",
          "text": "A mature oak drops 250,000 leaves each autumn.\nEach leaf returns 80% of its nutrients to the tree before falling.\nNothing is truly wasted in a forest.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "Climate change is shifting peak foliage later each decade.\nThe colours we grew up with are moving.\nBeauty itself is becoming a climate record.",
