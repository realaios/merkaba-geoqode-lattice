    "ancient_ruins_vr": {
      "id": "ancient_ruins_vr",
      "title": "Ancient Ruins — Roofless Stone Hall",
      "logline": "Roofless walls of a 2000-year-old stone hall. Open sky where the ceiling was. Time made visible.",
      "palette": "roman_arena",
      "sound": "ambient_wind",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "The Romans built structures that still stand 2000 years later.\nUsing no steel. No concrete additives. No power tools.\nThe secret: volcanic ash reacts with seawater to self-repair microcracks.",
          "durationMs": 8000
        },
        {
          "trigger": "step_1",
          "text": "Every ruin was someone's new building once.\nSomeone unlocked the door on the first day and thought: this will last forever.",
          "durationMs": 7000
        },
        {
          "trigger": "step_2",
          "text": "Archaeologists can map an entire buried city using radar.\nWithout digging a single hole.\nWe now see the past without touching it.",
          "durationMs": 7000
        }
      ],
      "environment": {
