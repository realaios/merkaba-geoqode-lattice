    "city_night_streets_vr": {
      "id": "city_night_streets_vr",
      "title": "City Night Streets — Urban Pulse",
      "logline": "Rain-slicked streets under sodium streetlights. The city breathes after dark.",
      "palette": "quantum",
      "sound": "ambient_city",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "More than half of all humans now live in cities.\nFor the first time in history, we are an urban species.\nThe city is our new nature.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "Wet asphalt reflects light at 300% efficiency compared to dry.\nThis is why rain-soaked city streets look more beautiful than dry ones.\nThe world improves when it rains.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "Edward Hopper painted empty late-night diners to capture urban loneliness.\nNighttime city scenes carry an emotional charge that daylight cannot.\nDarkness reveals what light conceals.",
          "durationMs": 9000
        }
      ],
      "environment": {
