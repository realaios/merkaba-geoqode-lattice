    "ornate_gardens_vr": {
      "id": "ornate_gardens_vr",
      "title": "Borghese Gardens — Rome Parkland",
      "logline": "The formal gardens of Villa Borghese. Rome’s green lung. Ancient pines frame distant domes.",
      "palette": "forest",
      "sound": "ambient_forest",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Villa Borghese was built in 1613 as a pleasure garden.\nIn 1901 it was donated to the city of Rome.\nPrivate paradise became public treasure.",
          "durationMs": 6000
        },
        {
          "trigger": "step_1",
          "text": "The stone pines of Rome — Pinus pinea — were planted by the Romans themselves.\nSome trees alive today were saplings when Michelangelo walked beneath them.\nTrees measure time we cannot.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "Rome has 14 major parks covering 15% of the city.\nA city that survived 2,800 years learned to breathe through its gardens.\nGreen space is infrastructure.",
          "durationMs": 8000
        }
      ],
      "environment": {
