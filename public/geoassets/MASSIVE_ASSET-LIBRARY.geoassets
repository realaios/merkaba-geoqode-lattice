    "nano_cave_vr": {
      "id": "nano_cave_vr",
      "title": "Nano Cave — Quantum Crystal Grotto",
      "logline": "Descend into a crystalline nano-cave where bioluminescent formations pulse with quantum energy.",
      "palette": "quantum",
      "sound": "ambient_cave",
      "narrativeBeats": [
