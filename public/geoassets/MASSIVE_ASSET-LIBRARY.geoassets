    "football_stadium_vr": {
      "id": "football_stadium_vr",
      "title": "Football Stadium — Arena Lights",
      "logline": "An empty stadium under floodlights. The pitch waits. Anticipation without release.",
      "palette": "simulation",
      "sound": "ambient_city",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Football is played in 200 countries — more than are members of the United Nations.\nIt is the only truly global sport. Every culture plays by the same 17 rules.\nThe pitch is a rare human universal.",
          "durationMs": 8000
        },
        {
          "trigger": "step_1",
          "text": "An empty stadium feels larger than a full one.\nWithout the crowd filling the geometry with sound and colour, the architecture becomes pure.\nAbsence reveals structure.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "The Camp Nou in Barcelona holds 99,354 people.\nOn match days, it becomes the 4th largest city in Catalonia.\nTemporary cities assemble and dissolve every two weeks.",
          "durationMs": 8000
        }
      ],
      "environment": {
