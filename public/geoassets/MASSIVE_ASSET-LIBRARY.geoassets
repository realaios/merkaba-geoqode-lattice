    "concrete_tunnel_vr": {
      "id": "concrete_tunnel_vr",
      "title": "Concrete Tunnel — Brutalist Passage",
      "logline": "Raw concrete corridors. The architecture of power stripped to pure geometry.",
      "palette": "simulation",
      "sound": "ambient_city",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Brutalism wasn’t an accident. It was a statement:\nthat material honesty matters more than decoration.",
          "durationMs": 6000
        },
        {
          "trigger": "step_1",
          "text": "Le Corbusier called concrete “beton brut” — raw concrete.\nThe word “Brutalism” was never about violence.\nIt was about truth.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "These buildings were designed to last centuries.\nMany were demolished within decades.\nWe build permanence, then change our minds.",
          "durationMs": 8000
        }
      ],
      "environment": {
