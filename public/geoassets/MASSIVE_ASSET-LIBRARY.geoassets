    "neon_tunnel_vr": {
      "id": "neon_tunnel_vr",
      "title": "Neon Mosaic Tunnel — Light Art Passage",
      "logline": "A pedestrian tunnel tiled floor to ceiling in Byzantine mosaic. Every surface glows in coloured light.",
      "palette": "simulation",
      "sound": "ambient_city",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Byzantine mosaic artists placed tiles at slight angles.\nTo catch light differently throughout the day.\nThey designed time into art in the 5th century.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "The Leadenhall tunnel in London has mosaic from 1881.\nIt survived two world wars, the Blitz, and the financial crisis.\nBeauty outlasts everything.",
          "durationMs": 7000
        },
        {
          "trigger": "step_2",
