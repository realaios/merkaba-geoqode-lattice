    "red_hills_vr": {
      "id": "red_hills_vr",
      "title": "Red Hills — Karoo Landscape",
      "logline": "Burning red hills of the South African Karoo. Ancient rock, sparse scrub, silence and scale.",
      "palette": "desert_dawn",
      "sound": "ambient_wind",
      "narrativeBeats": [
