    "moon_laboratory": {
      "id": "moon_laboratory",
      "title": "Moon Laboratory — Lunar Research Station",
      "logline": "A research habitat on the lunar surface. Science at the edge of everything. Earth hangs silent above.",
      "palette": "orbital",
      "sound": "ambient_night",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "The Moon has no atmosphere.\nEvery sunrise and sunset happens in complete silence.\nThe sky goes from black to black in seconds.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "NASA's Artemis program will put humans back on the Moon by 2026.\nThis time to stay.\nThe first lunar base will be built from moon dust, using 3D printing.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "Lunar regolith is razor-sharp.\nApollo astronauts found it cut through suit material in hours.\nThe Moon tries to kill you at the microscopic level.",
          "durationMs": 8000
        }
      ],
      "environment": {
        "sky": {
          "color": "#030712"
