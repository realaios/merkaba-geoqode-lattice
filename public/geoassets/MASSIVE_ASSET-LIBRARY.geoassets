    "starfield_night_vr": {
      "id": "starfield_night_vr",
      "title": "Starfield Night — The Infinite Archive",
      "logline": "Pure darkness shattered by ten thousand stars — each one a timestamp in the universe's autobiography.",
      "palette": "deep_space",
      "sound": "ambient_space",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "You are not looking at the sky. You are looking back in time — 4,000 years per light-year.",
          "durationMs": 8000
        },
        {
