    "gothic_cathedral_vr": {
      "id": "gothic_cathedral_vr",
      "title": "Gothic Cathedral — Sacred Vaults",
      "logline": "Inside a medieval cathedral. Light through rose windows. Stone prayers frozen in time.",
      "palette": "merkaba",
      "sound": "ambient_cosmic",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Notre-Dame de Paris took 182 years to build, from 1163 to 1345.\nThe architects who began it would never see it complete.\nCathedrals are built across generations — an act of faith in the future.",
          "durationMs": 9000
        },
        {
          "trigger": "step_1",
          "text": "Gothic vaulted ceilings redirect the weight of the stone outward through flying buttresses.\nThis allows walls to become windows — stone dissolves into light.\nThe entire structural system is a philosophy made physical.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "The oldest stained glass in the world is at Augsburg Cathedral, made in 1065 AD.\nGlass is technically a supercooled liquid — it flows imperceptibly over centuries.\nAncient windows are thicker at the bottom than the top.",
          "durationMs": 9000
        }
      ],
      "environment": {
        "sky": {
          "color": "#1e1b4b"
        },
        "fog": {
          "color": "#312e81",
          "density": 0.012
        }
      },
      "layers": [
        {
