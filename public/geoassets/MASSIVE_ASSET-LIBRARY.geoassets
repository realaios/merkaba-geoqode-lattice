    "colosseum_time_gate_vr": {
      "id": "colosseum_time_gate_vr",
      "title": "Colosseum Time Gate — Ancient Arena",
      "logline": "The Colosseum at the golden hour. 2,000 years of stone and shadow.",
      "palette": "roman_arena",
      "sound": "ambient_wind",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "The Colosseum was completed in 80 AD and could seat 80,000 spectators.\nIts elliptical design meant every seat had a clear view of the arena floor.\nThe Romans mastered crowd psychology before they mastered architecture.",
          "durationMs": 9000
        },
        {
          "trigger": "step_1",
          "text": "The arena floor was called the 'harena' — Latin for sand.\nSand was used to absorb blood. The word 'arena' has never lost its original meaning.\nLanguage remembers what history prefers to forget.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "The Colosseum has been damaged by 4 major earthquakes since it was built.\nHalf of the original structure was quarried for other Roman buildings in the Middle Ages.\nWe build monuments. Then we cannibalise them. Then we mourn their loss.",
          "durationMs": 10000
        }
      ],
      "environment": {
        "sky": {
          "color": "#92400e"
        },
        "fog": {
