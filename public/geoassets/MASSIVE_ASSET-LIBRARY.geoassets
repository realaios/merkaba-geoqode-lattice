    "safari_sunset_vr": {
      "id": "safari_sunset_vr",
      "title": "Safari Sunset — African Savanna",
      "logline": "Golden hour on the savanna. Acacia silhouettes against fire-orange sky. The Serengeti at dusk.",
      "palette": "golden_hour",
      "sound": "ambient_wind",
      "narrativeBeats": [
