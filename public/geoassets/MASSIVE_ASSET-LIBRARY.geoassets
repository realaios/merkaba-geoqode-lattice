    "forest_528hz_vr": {
      "id": "forest_528hz_vr",
      "title": "Forest 528Hz — Sacred Grove",
      "logline": "A sun-dappled forest resonating at 528Hz. Ancient trees. The frequency of restoration.",
      "palette": "forest",
      "sound": "ambient_forest",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "528Hz is known as the 'Miracle Tone' — the frequency of transformation and DNA repair.\nForests naturally produce soundscapes in this frequency range through insect and bird calls.\nThe ancient world knew the forest was medicine.",
          "durationMs": 9000
        },
        {
          "trigger": "step_1",
          "text": "Trees in a forest communicate through mycorrhizal networks — fungal threads connecting roots.\nA mother tree can send carbon, water, and even chemical defence signals to her offspring.\nThe forest floor is a living internet.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "Shinrin-yoku — 'forest bathing' — is prescribed by Japanese physicians.\nTwo hours in a forest reduces cortisol by 16%, blood pressure by 5%, heart rate by 4%.\nThe dose makes the medicine. And the forest is free.",
          "durationMs": 9000
        }
      ],
      "environment": {
        "sky": {
          "color": "#14532d"
        },
        "fog": {
          "color": "#166534",
          "density": 0.015
        }
      },
      "layers": [
