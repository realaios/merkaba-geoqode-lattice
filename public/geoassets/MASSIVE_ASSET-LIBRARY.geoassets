    "stone_alley_vr": {
      "id": "stone_alley_vr",
      "title": "Stone Alley — Ancient Urban Passage",
      "logline": "A narrow alley between old stone walls. Worn cobblestones, iron lanterns, centuries of footsteps.",
      "palette": "merkaba",
      "sound": "ambient_night",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "The narrowest alley in the world is in Vienna: 52cm wide.\nAll of history, compressed.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "Medieval cities were built narrow on purpose.\nShade in summer. Shelter from wind. Fewer surfaces to heat.\nOld cities were climate-adapted before the word existed.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "Every cobblestone was laid by hand.\nSome of these roads have been walked for 800 years.\nYou walk on the work of the forgotten.",
          "durationMs": 7000
