    "night_bridge_vr": {
      "id": "night_bridge_vr",
      "title": "Night Bridge — Crossing Dark Water",
      "logline": "A wooden bridge spans black water at midnight. City glow on the horizon. Polyhaven night sky above.",
      "palette": "deep_space",
      "sound": "ambient_night",
      "narrativeBeats": [
