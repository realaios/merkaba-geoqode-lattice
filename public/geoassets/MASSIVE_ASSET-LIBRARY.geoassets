    "coastal_cliff_vr": {
      "id": "coastal_cliff_vr",
      "title": "Coastal Cliffside — Sea Views",
      "logline": "Standing on the edge of a coastal cliff. Wind. Seabirds. The Atlantic churning below.",
      "palette": "ocean",
      "sound": "ambient_ocean",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Coastal cliffs are the planet’s slowest moving objects.\nThey retreat between 1 cm and 1 metre per year.\nTime made visible in stone.",
          "durationMs": 6000
        },
        {
          "trigger": "step_1",
          "text": "The Cliffs of Moher in Ireland took 300 million years to form.\nThey are made from the bodies of sea creatures.\nYou stand on compressed ancient life.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "Rising seas accelerate cliff erosion by 50–100%.\nWhole villages have disappeared into the North Sea in a generation.\nThe land is becoming ocean again.",
