    "abandoned_factory": {
      "id": "abandoned_factory",
      "title": "Abandoned Factory — Industrial Ruin",
      "logline": "Derelict industrial warehouse. Broken skylights. Nature reclaiming concrete. Rust and silence.",
      "palette": "simulation",
      "sound": "ambient_industrial",
