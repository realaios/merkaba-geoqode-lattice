    "bamboo_forest_vr": {
      "id": "bamboo_forest_vr",
      "title": "Bamboo Forest — Cathedral Path",
      "logline": "A bamboo tunnel path. Shafts of filtered light. The sound of hollow stalks in wind.",
      "palette": "forest",
      "sound": "ambient_jungle",
      "narrativeBeats": [
