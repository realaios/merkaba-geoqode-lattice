    "industrial_sunset_vr": {
      "id": "industrial_sunset_vr",
      "title": "Industrial Sunset — Golden Haze",
      "logline": "A refinery at golden hour. Flames on stacks. The sun sets behind iron towers.",
      "palette": "desert_dawn",
      "sound": "ambient_city",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Industrial facilities often produce the most dramatic sunsets.\nParticulates in the air scatter longer wavelengths.\nPollution creates its own beauty as it fades.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "The first oil refinery opened in 1856.\nIn 170 years, we built an entire civilisation on extraction.\nNow we must learn to build one on restoration.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "The last oil refinery will probably close around 2060.\nSomeone alive today will watch it.\nIndustry doesn’t end — it transforms.",
          "durationMs": 7000
        }
      ],
      "environment": {
