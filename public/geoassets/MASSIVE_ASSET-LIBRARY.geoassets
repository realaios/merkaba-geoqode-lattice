    "rooftop_night_vr": {
      "id": "rooftop_night_vr",
      "title": "Rooftop Night — Urban Zenith",
      "logline": "The city stretches to the horizon below. Up here, the noise becomes music and the chaos becomes pattern.",
      "palette": "abyss",
      "sound": "ambient_city_night",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Seven million stories below. From up here, every light is a life, a dream, a data point.",
          "durationMs": 8000
        },
        {
          "trigger": "step_1",
          "text": "The city is a neural network running in real time. You are standing on a synapse.",
          "durationMs": 8000
        },
