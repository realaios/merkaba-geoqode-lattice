    "pyramids_giza_vr": {
      "id": "pyramids_giza_vr",
      "title": "Pyramids of Giza — Eternal Horizon",
      "logline": "Stand at the base of the ancient pyramids as the desert wind carries 4,500 years of secrets.",
      "palette": "desert_dawn",
