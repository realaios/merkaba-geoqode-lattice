    "gothic_cathedral": {
      "id": "gothic_cathedral",
      "title": "Gothic Cathedral — Vaulted Infinity",
      "logline": "14th century cathedral interior. Polyhaven skylight. Rose windows. Organ resonance at 432 Hz.",
      "palette": "merkaba",
      "sound": "ambient_organ",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Gothic architecture was engineering as theology.\nEvery pointed arch is a prayer compressed into physics.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "The builders worked for 200 years.\nNo one who laid the foundation lived to see the spire completed.",
          "durationMs": 7000
