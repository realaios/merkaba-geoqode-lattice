    "tron_grid": {
      "id": "tron_grid",
      "title": "TRON Grid — Digital Infinity",
      "logline": "Inside a digital grid. Neon blue wireframe. The aesthetic memory of every 80s sci-fi dream.",
      "palette": "simulation",
      "sound": "ambient_synth",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "You're inside the machine.\nEvery line of this grid was once a thought that became code.",
          "durationMs": 7000
