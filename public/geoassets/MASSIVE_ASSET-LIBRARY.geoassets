    "deep_space_vr": {
      "id": "deep_space_vr",
      "title": "Deep Space — Stellar Void",
      "logline": "Beyond the heliosphere. Infinite dark punctuated by ancient light.",
      "palette": "deep_space",
      "sound": "ambient_cosmic",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "The observable universe is 93 billion light-years in diameter.\nThe light from the most distant stars left before Earth existed.\nWe are surrounded by messages from the past.",
          "durationMs": 8000
        },
        {
          "trigger": "step_1",
          "text": "There are more stars in the observable universe than grains of sand on all of Earth's beaches.\nYet space is so vast that the nearest star is 4.24 light-years away.\nAbundance and emptiness coexist at cosmic scale.",
          "durationMs": 9000
        },
        {
          "trigger": "step_2",
          "text": "The Voyager 1 probe has been travelling for 47 years and is still inside our solar system.\nTo reach the nearest star at Voyager's speed would take 73,000 years.\nDistance is the universe's primary language.",
          "durationMs": 9000
        }
      ],
      "environment": {
        "sky": {
