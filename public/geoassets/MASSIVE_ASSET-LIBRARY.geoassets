    "rock_castle_vr": {
      "id": "rock_castle_vr",
      "title": "Rock Castle — Neurathen Sandstone",
      "logline": "A medieval castle carved from living sandstone. Saxon Switzerland. Stone walls grown from the earth itself.",
      "palette": "roman_arena",
      "sound": "ambient_forest",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "Burg Neurathen in Saxon Switzerland is one of the largest rock castles in Germany.\nBuilt by carving directly into the sandstone.\nThe rock is both foundation and wall.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "Saxon Switzerland is named not for Switzerland, but by two Swiss painters\nwho thought the landscape reminded them of home.\nPlace names carry old homesickness.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "These sandstone pillars formed 70 million years ago as sea sediment.\nThey became rock, then were carved into castles, then became national parks.\nTime transforms everything it touches.",
          "durationMs": 8000
        }
      ],
      "environment": {
