    "white_cliffs_vr": {
      "id": "white_cliffs_vr",
      "title": "White Cliffs — Dover Coast",
      "logline": "The chalky white cliffs of Dover. England’s most iconic edge. The Channel silver below.",
      "palette": "ocean",
      "sound": "ambient_ocean",
      "narrativeBeats": [
        {
          "trigger": "enter",
          "text": "The White Cliffs of Dover are made of coccolithophores —\nmicroscopic algae that lived 90 million years ago.\nThe cliff is a graveyard visible from space.",
          "durationMs": 7000
        },
        {
          "trigger": "step_1",
          "text": "The English Channel is only 34 km at its narrowest.\nJulius Caesar crossed it in 55 BC.\nFor 2,000 years this was the boundary of worlds.",
          "durationMs": 8000
        },
        {
          "trigger": "step_2",
          "text": "The cliffs lose over 10,000 tonnes of chalk to the sea each year.\nBy 2100, they could be 40 metres shorter.\nThe coast is not a constant — it is a direction.",
          "durationMs": 8000
        }
      ],
      "environment": {
