{
  "name": "merkaba-game-agent",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create merkaba-knowledge",
    "db:migrate": "wrangler d1 execute merkaba-knowledge --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute merkaba-knowledge --remote --file=./schema.sql",
    "trigger": "curl -X POST http://localhost:8787/trigger",
    "status": "curl http://localhost:8787/status"
  },
  "dependencies": {
    "agents": "^0.0.94",
    "@ai-sdk/anthropic": "^1.2.12",
    "ai": "^4.3.16",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.20.1"
  }
}
